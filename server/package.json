{
  "name": "urbancruise-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "tsx src/db/config.ts",
    "db:studio": "drizzle-kit studio"
